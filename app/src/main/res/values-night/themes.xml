<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:buttonStyle">@style/CustomButtonStyle</item>
        <item name="colorPrimary">#3867d6</item>
        <item name="colorPrimaryDark">#000000</item>
        <item name="colorAccent">#ffff</item>
        <item name="fontFamily">@font/roboto_regular</item>

        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
    </style>

    <style name="CustomButtonStyle" parent="Widget.AppCompat.Button">
        <item name="android:textColor">#ffffff</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Theme.MyApplication" parent="Base.Theme.MyApplication" />

    <style name="App.Custom.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/yellow</item>
    </style>

    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_in_bottom</item>
        <item name="android:windowExitAnimation">@anim/slide_out_bottom</item>
    </style>



<!--    My themes-->

    <style name="backgrounds">
        <item name="android:background">@color/black</item>
    </style>

    <style name="cards">
        <item name="android:background">@color/white</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="spinner">
        <item name="android:background">@color/black</item>
        <item name="android:indeterminateTint">@color/white</item>
    </style>

    <style name="spinner_overlay">
        <item name="android:background">@color/black</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
    </style>

    <style name="actions">
        <item name="android:background">@color/black</item>
        <item name="android:tint">@color/white</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="texts">
        <item name="android:textColor">@color/white</item>
        <item name="android:fillColor">@color/white</item>
    </style>


    <style name="cardShadow">
        <item name="android:outlineSpotShadowColor">@color/white</item>
    </style>

    <style name="headers">
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@color/black</item>
        <item name="android:textSize">@dimen/_20ssp</item>
    </style>

</resources>
